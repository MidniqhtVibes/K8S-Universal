
# ---------------------------------------------------------------------------
# Compose / images
# ---------------------------------------------------------------------------

COMPOSE_PROJECT_NAME=k8s-universal


BUILDER_VERSION=latest

BUILDER_WEB_IMAGE=ghcr.io/midniqhtvibes/k8s-universal-web
BUILDER_WORKER_IMAGE=ghcr.io/midniqhtvibes/k8s-universal-worker

# Normally leave this as .env.
BUILDER_ENV_FILE=.env


# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------

# Prefer a long URL-safe value because the password is currently embedded
# directly in DATABASE_URL by compose.yaml.
# Example generator:
#   openssl rand -hex 32
POSTGRES_PASSWORD=password


# ---------------------------------------------------------------------------
# Application security
# ---------------------------------------------------------------------------

# Generate independent values. Example:
#   openssl rand -hex 32
MASTER_KEY=password
SESSION_SECRET=password

# Used for the initial administrator account.
INITIAL_ADMIN_PASSWORD=password


# ---------------------------------------------------------------------------
# HTTP
# ---------------------------------------------------------------------------

# 127.0.0.1 = only locally reachable.
# Set an appropriate trusted private interface when remote access is required.
BUILDER_BIND_ADDRESS=127.0.0.1
BUILDER_PORT=8000
SESSION_HTTPS_ONLY=false


# ---------------------------------------------------------------------------
# Provisioning worker
# ---------------------------------------------------------------------------

TERRAFORM_PARALLELISM=2
ANSIBLE_FORKS=4


# ---------------------------------------------------------------------------
# Jobs / retention
# ---------------------------------------------------------------------------

STALE_JOB_TIMEOUT_MINUTES=60
JOB_RETENTION_KEEP=100
MANIFEST_REVISION_RETENTION_KEEP=30
